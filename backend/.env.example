# ============================================================================
# FOCUSAINT BACKEND ENVIRONMENT CONFIGURATION
# ============================================================================
# This file contains all environment variables required for the backend server.
# Copy this file to .env and fill in the appropriate values for your environment.
#
# SECURITY WARNING: Never commit the .env file to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------------------------------

# Server port number (default: 5000)
PORT=5000

# Application environment: development, staging, production, test
# REQUIRED: Must be set to appropriate environment
NODE_ENV=development

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------

# MongoDB connection string
# REQUIRED: Must be a valid MongoDB URI
# Local: mongodb://localhost:27017/focusaint
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/focusaint
MONGODB_URI=mongodb://localhost:27017/focusaint

# ----------------------------------------------------------------------------
# REDIS CONFIGURATION
# ----------------------------------------------------------------------------

# Redis connection URL for caching and rate limiting
# REQUIRED: Must be a valid Redis URL
# Local: redis://localhost:6379
# Redis Cloud: redis://username:password@host:port
# Upstash: redis://:password@host:port
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# ----------------------------------------------------------------------------

# JWT Secret for token signing
# REQUIRED: Must be at least 32 characters long
# PRODUCTION WARNING: Must be changed from default value in production!
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=focusaint_secret_key_change_in_production

# ----------------------------------------------------------------------------
# CORS CONFIGURATION
# ----------------------------------------------------------------------------

# Comma-separated list of allowed CORS origins
# REQUIRED: Must include at least one origin
# Development: http://localhost:3000
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:3000

# Primary frontend URL (required in production)
# Used for email links, redirects, and other frontend references
FRONTEND_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# ----------------------------------------------------------------------------

# Email service provider: 'gmail' or leave empty for custom SMTP
# Options: gmail, custom, or empty string
EMAIL_SERVICE=gmail

# Email address for sending emails (OTP, notifications, etc.)
# REQUIRED: Must be a valid email address
# For Gmail: your-email@gmail.com
# For custom SMTP: any valid email address
EMAIL_USER=your-email@gmail.com

# Email password or app-specific password
# REQUIRED: Must be at least 8 characters
# For Gmail: Generate App Password at https://myaccount.google.com/apppasswords
# For custom SMTP: Your email account password
EMAIL_PASSWORD=your-app-password-here

# ----------------------------------------------------------------------------
# CUSTOM SMTP CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# Only required if EMAIL_SERVICE is not 'gmail'
# Uncomment and configure these if using a custom SMTP service

# SMTP server hostname
# SMTP_HOST=smtp.gmail.com

# SMTP server port (usually 587 for TLS, 465 for SSL)
# SMTP_PORT=587

# Use TLS for SMTP connection (true/false)
# SMTP_SECURE=false

# Example configurations for popular email services:
# ----------------------------------------------------------------------------
# Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# Mailgun:
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# AWS SES:
#   SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# Outlook/Office365:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false

# ----------------------------------------------------------------------------
# EXTERNAL SERVICES (Optional - for premium features)
# ----------------------------------------------------------------------------

# Stripe API keys for payment processing
# Required for subscription management and premium features
# Get keys from: https://dashboard.stripe.com/apikeys
# Test mode keys (use for development):
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs for subscription plans
# Create these in Stripe Dashboard under Products
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_YEARLY=price_your_yearly_price_id

# ==============================================================================
# AI PROVIDER SETTINGS (Bedrock, Groq, Gemini)
# ==============================================================================
# AI Features Toggle
AI_ENABLED=true
AI_CACHE_ENABLED=true

# Groq (Primary Speed - 280 TPS)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# AWS Bedrock (Reliability & Batch)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
BEDROCK_MODEL_ID=meta.llama3-70b-instruct-v1:0
BEDROCK_TECHNICAL_MODEL_ID=meta.llama3-70b-instruct-v1:0
S3_BATCH_BUCKET=your-focusaint-ai-batch-bucket
S3_BUCKET_NAME=your-focusaint-uploads-bucket
AWS_BATCH_ROLE_ARN=arn:aws:iam::your-account-id:role/BedrockBatchRole

# Gemini (Legacy / Long Context)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta


# Sentry DSN for error tracking and monitoring
# Required for production error tracking
# Get DSN from: https://sentry.io/settings/projects/
SENTRY_DSN=

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------------------

# Log level: error, warn, info, http, debug
# REQUIRED: Must be one of the valid log levels
# Development: debug (most verbose)
# Staging: info
# Production: warn or error (least verbose)
LOG_LEVEL=debug

# Disable all logging (useful for testing)
# Options: true, false
# Default: false
# LOG_SILENT=false

# ----------------------------------------------------------------------------
# ENVIRONMENT-SPECIFIC NOTES
# ----------------------------------------------------------------------------

# DEVELOPMENT:
# - Use local MongoDB and Redis instances
# - JWT_SECRET can be the default value
# - CORS_ORIGIN should include http://localhost:3000
# - External services (Stripe, Gemini, Sentry) are optional

# STAGING:
# - Should mirror production configuration
# - Use staging databases and services
# - Test payment processing with Stripe test mode
# - Enable Sentry for error tracking

# PRODUCTION:
# - All required fields must be set
# - JWT_SECRET must be a strong, unique value (not the default!)
# - Use production MongoDB Atlas cluster
# - Use production Redis instance (Redis Cloud, Upstash, etc.)
# - CORS_ORIGIN must include only trusted production domains
# - FRONTEND_URL must be set to production domain
# - Enable all external services (Stripe, Gemini, Sentry)
# - Verify all credentials are production-ready
# - Enable HTTPS for all connections

# ----------------------------------------------------------------------------
# VALIDATION
# ----------------------------------------------------------------------------
# The application will validate all required environment variables on startup.
# If any required variables are missing or invalid, the server will not start.
# Check the console output for detailed validation errors.
